# Copy this to a real .env file at the repo root (or export these as real
# environment variables). Do NOT commit a real .env — .gitignore already
# excludes it.
#
#   macOS / Linux:   export ANTHROPIC_API_KEY=sk-ant-...
#   PowerShell:      $env:ANTHROPIC_API_KEY = "sk-ant-..."
#
# scripts/brain.py auto-loads a .env file at the repo root if these aren't
# already set as real environment variables — see brain.py's load_dotenv().

# Required for scripts/test_brain.py (Phase 1) and server/llm_proxy.py (Phase 2).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required for server/llm_proxy.py (Phase 2) only. Any long random string —
# generate one with: python -c "import secrets; print(secrets.token_hex(24))"
# Set the SAME value in the ElevenLabs agent's Custom LLM "API key" field —
# see docs/VOICE_INTEGRATION.md. This is NOT your Anthropic key; it just
# stops a stumbled-upon public tunnel URL from running up your API bill.
PROXY_SHARED_SECRET=a-long-random-string-here
