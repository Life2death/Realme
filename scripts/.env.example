# Copy this to a real environment variable before running the test harness.
# Do NOT commit a real key.
#
#   macOS / Linux:   export ANTHROPIC_API_KEY=sk-ant-...
#   PowerShell:      $env:ANTHROPIC_API_KEY = "sk-ant-..."
#
# The script reads the key from the environment automatically via
# anthropic.Anthropic(); it never takes the key as an argument.

ANTHROPIC_API_KEY=sk-ant-your-key-here
